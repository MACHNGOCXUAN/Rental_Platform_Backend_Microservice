// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/**
 * Ai nhận notification
 * Không phụ thuộc user-service
 */
enum ReceiverType {
  USER
  ADMIN
}

/**
 * Loại thông báo theo NGỮ CẢNH
 * Không gắn với role
 */
enum NotificationType {
  RENTAL_REQUEST
  RENTAL_REQUEST_UPDATE
  PROPERTY_UPDATE
  CONTRACT_CREATED
  CONTRACT_UPDATED
  CONTRACT_SIGNED
  CONTRACT_TERMINATION
  DEPOSIT_PAYMENT
  PAYMENT
  PAYMENT_REMINDER
  PAYMENT_DUE
  PAYMENT_WARNING
  PAYMENT_OVERDUE
  REPORT_CREATED
  REPORT_RESOLVED
  REPORT_CANCELLED
  SYSTEM
  ADMIN_ACTION
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
  READ
}

model Notification {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  title String
  body  String

  type NotificationType

  priority NotificationPriority @default(NORMAL)

  actionUrl   String?
  actionLabel String?
  imageUrl    String?

  /**
   * Metadata linh hoạt (event payload)
   * Ví dụ: { propertyId, contractId }
   */
  metadata Json?

  recipients NotificationRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationRecipient {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  notificationId String @db.ObjectId
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  receiverId   String
  receiverType ReceiverType

  channel NotificationChannel @default(IN_APP)
  status  DeliveryStatus      @default(PENDING)

  isRead  Boolean   @default(false)
  readAt  DateTime?
  deliveredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([receiverId, isRead, createdAt(sort: Desc)])
  @@index([notificationId])
  @@index([receiverType])
  @@map("notification_recipients")
}

model NotificationPreference {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  receiverId   String
  receiverType ReceiverType

  inAppEnabled Boolean @default(true)
  emailEnabled Boolean @default(true)
  smsEnabled   Boolean @default(false)
  pushEnabled  Boolean @default(true)

  quietHours Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([receiverId, receiverType])
  @@map("notification_preferences")
}

model NotificationDevice {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  receiverId   String
  receiverType ReceiverType

  token    String
  platform String @default("WEB")
  deviceId String?

  lastSeenAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([token])
  @@index([receiverId, receiverType])
  @@map("notification_devices")
}
