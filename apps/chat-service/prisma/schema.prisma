generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  AUDIO
  VIDEO
  CALL_VOICE    // Cuộc gọi thoại
  CALL_VIDEO    // Cuộc gọi video
  CALL_MISSED   // Cuộc gọi nhỡ
}

enum ConversationStatus {
  ACTIVE
  BLOCKED
}

enum CallType {
  VOICE
  VIDEO
}

enum CallStatus {
  RINGING
  ACCEPTED
  ENDED
  REJECTED
  MISSED
  CANCELED
  FAILED
}

model Conversation {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId

  user1Id        String
  user2Id        String

  status         ConversationStatus @default(ACTIVE)

  isPinnedByUser1    Boolean @default(false)
  isPinnedByUser2    Boolean @default(false)
  isArchivedByUser1  Boolean @default(false)
  isArchivedByUser2  Boolean @default(false)

  lastMessage        String?
  lastMessageAt      DateTime @default(now())
  lastMessageType    MessageType?
  lastMessageSender  String?

  lastReadByUser1    DateTime?
  lastReadByUser2    DateTime?

  unreadCountUser1   Int @default(0)
  unreadCountUser2   Int @default(0)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  messages           Message[]
  callSessions       CallSession[]
  categories         ConversationCategory[]   // 👈 thêm dòng này

  @@unique([user1Id, user2Id])
  @@index([user1Id, lastMessageAt(sort: Desc)])
  @@index([user2Id, lastMessageAt(sort: Desc)])
  @@index([lastMessageAt(sort: Desc)])
  @@map("conversations")
}


model CallSession {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId

  conversationId String   @db.ObjectId
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  callerId       String
  calleeId       String

  callType       CallType
  status         CallStatus @default(RINGING)

  startedAt      DateTime @default(now())
  answeredAt     DateTime?
  endedAt        DateTime?
  duration       Int?
  endReason      String?

  updatedAt      DateTime @updatedAt

  @@index([conversationId, startedAt(sort: Desc)])
  @@index([callerId, startedAt(sort: Desc)])
  @@index([calleeId, startedAt(sort: Desc)])
  @@index([status])
  @@map("call_sessions")
}


model Message {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId

  conversationId   String   @db.ObjectId
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId         String
  content          String?

  messageType      MessageType @default(TEXT)

  fileUrl          String?
  fileName         String?
  fileSize         Int?
  mimeType         String?
  width            Int?
  height           Int?
  duration         Int?
  thumbnailUrl     String?

  replyToId   String?   @db.ObjectId
  replyTo     Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies     Message[] @relation("MessageReplies")

  isDelivered      Boolean @default(false)

  isDeleted        Boolean  @default(false)
  deletedAt        DateTime?

  reactions        Json?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
  @@map("messages")
}


model CustomerCategory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  userId      String

  name        String
  color       String?
  description String?

  conversationLinks ConversationCategory[]   // 👈 thêm

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@unique([userId, name])
  @@map("customer_categories")
}


model ConversationCategory {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId

  conversationId String   @db.ObjectId
  userId         String
  categoryId     String   @db.ObjectId

  conversation   Conversation      @relation(fields: [conversationId], references: [id])
  category       CustomerCategory  @relation(fields: [categoryId], references: [id])

  createdAt      DateTime @default(now())

  @@unique([conversationId, categoryId])
  @@index([userId])
}


